NODE_ENV=production
PORT=3022
PUBLIC_BASE_URL=https://altezzaeventos.in

ALTEZZA_DB_HOST=127.0.0.1
ALTEZZA_DB_PORT=3306
ALTEZZA_DB_NAME=feegosys_Altezza
ALTEZZA_DB_USER=feegosys_Altezza
ALTEZZA_DB_PASS=CHANGE_ME

ALTEZZA_DATA_ROOT=/srv/altezza
# optional:
# ALTEZZA_EVENTOS_DIR=/srv/altezza/images/eventos

# Local dev: store runtime files inside the repo (ignored by git)
# ALTEZZA_DATA_ROOT=./_local_storage

# Where event images are stored on disk (defaults to $ALTEZZA_DATA_ROOT/images/eventos)
# ALTEZZA_EVENTOS_DIR=./_local_storage/images/eventos

# Public path where images are served (same path used in production nginx)
# ALTEZZA_EVENTOS_PUBLIC_PATH=/scrAppaltezza/images/eventos
